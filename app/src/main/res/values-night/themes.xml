<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.SmartSplit" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/textOnPrimary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/textOnPrimary</item>

        <!-- Backgrounds -->
        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="android:colorBackground">@color/backgroundColor</item>
        <item name="colorSurface">@color/surfaceColor</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorSurfaceVariant">@color/surfaceVariant</item>

        <!-- Status bar – dark bg, light icons -->
        <item name="android:statusBarColor">@color/backgroundColor</item>
        <item name="android:windowLightStatusBar" tools:ignore="NewApi">false</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">#1A1CC29F</item>
    </style>

    <style name="Theme.SmartSplit" parent="Base.Theme.SmartSplit" />

    <style name="Theme.SmartSplit.Splash" parent="Theme.SmartSplit">
        <item name="android:windowBackground">@color/colorPrimaryDark</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
    </style>

</resources>