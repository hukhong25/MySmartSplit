<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvNotifTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/viewUnreadDot"
        android:layout_marginEnd="8dp"
        android:text="Title" />

    <TextView
        android:id="@+id/tvNotifContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#64748B"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvNotifTitle"
        app:layout_constraintEnd_toStartOf="@+id/viewUnreadDot"
        android:layout_marginEnd="8dp"
        android:text="Content" />

    <TextView
        android:id="@+id/tvNotifTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#94A3B8"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvNotifContent"
        app:layout_constraintEnd_toStartOf="@+id/viewUnreadDot"
        android:layout_marginEnd="8dp"
        android:text="Time" />

    <View
        android:id="@+id/viewUnreadDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/circle_unread"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
