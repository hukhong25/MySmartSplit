<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/cardBackground"
    app:strokeColor="@color/dividerColor"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar circle with initials -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp">

            <View
                android:id="@+id/viewAvatarBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_circle"/>

            <TextView
                android:id="@+id/tvAvatarInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="A"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </FrameLayout>

        <!-- Name + Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên thành viên"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:id="@+id/tvBalanceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nợ bạn ₫450,000"
                android:textSize="12sp"
                android:textColor="@color/colorOwe"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Action button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBalanceAction"
            style="@style/Widget.SmartSplit.Button.SettleUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tất toán"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>